# Copy to .env for local testing (PowerShell users: see README for how to load it).
# On GitHub these are set as repo Secrets instead, NOT committed.
# Configure Telegram and/or WhatsApp — the bot sends to whichever are set.

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp via CallMeBot (optional, free) ---
WHATSAPP_PHONE=+919876543210
WHATSAPP_APIKEY=123456

# --- Discord via Incoming Webhook (optional, free) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123/abc

# --- Aggregator API keys (optional, free; sources stay off until set) ---
# Adzuna: register at https://developer.adzuna.com  -> app id + key
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
# Jooble: register at https://jooble.org/api/about  -> api key
JOOBLE_API_KEY=your_jooble_key
